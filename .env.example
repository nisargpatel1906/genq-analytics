# AI provider: openrouter or nvidia
LLM_PROVIDER=openrouter
LLM_MODE=agentic
LLM_MAX_REGENERATION_ROUNDS=3
LLM_FALLBACK_PROVIDER=nvidia

# NVIDIA NIM configuration (fallback)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model selection
LLM_DOMAIN_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
LLM_ANALYSIS_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
LLM_VISUAL_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
LLM_REPORT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
LLM_REVIEW_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
LLM_CHAT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# OpenRouter (primary - free tier)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

DATABASE_URL=postgresql://user:pass@localhost:5432/genq
REDIS_URL=redis://localhost:6379
MAX_FILE_SIZE_MB=500
ANALYSIS_TIMEOUT_SECONDS=180
FILE_RETENTION_HOURS=24

# Agent execution mode
# Set to true to have agents generate and execute Jupyter notebooks (.ipynb) for analysis
# Set to false to fall back to flat Python script execution
ENABLE_NOTEBOOK_MODE=true
# Set to false to skip the Narrative Stitcher agent (faster but less polished executive summary)
LLM_NARRATIVE_STITCHER=true

# Local Ollama Configuration (Optional)
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=gemma4:12b

# Shared API Key Authentication
GENQ_API_KEY=your_genq_api_key_here
